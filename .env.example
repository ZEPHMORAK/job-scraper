# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=123456789

# ─── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password_here

# ─── SEARCH KEYWORDS ──────────────────────────────────────────────────────────
# Comma-separated list of keywords to search on Upwork and LinkedIn
UPWORK_KEYWORDS=web automation,AI integration,real estate tech,coaching platform,CRM development
LINKEDIN_KEYWORDS=automation consultant,AI developer,real estate technology,coaching platform

# ─── GOOGLE MAPS (OPTIONAL) ───────────────────────────────────────────────────
# Leave blank to skip Google Maps lead generation
GOOGLE_MAPS_API_KEY=
# Comma-separated queries for Google Maps business discovery
GMAPS_QUERIES=real estate agents Lagos,business coaches Lagos,property consultants Abuja

# ─── FILTER SETTINGS ──────────────────────────────────────────────────────────
MIN_BUDGET=100
MIN_SCORE=7

# ─── SYSTEM SETTINGS ──────────────────────────────────────────────────────────
MODE=SAFE
TONE=professional
SCHEDULE_HOURS=12

# ─── DAILY LIMITS ─────────────────────────────────────────────────────────────
DAILY_UPWORK_LIMIT=20
DAILY_LINKEDIN_LIMIT=30
DAILY_EMAIL_LIMIT=50

# ─── YOUR OFFER (used in AI-generated messages) ───────────────────────────────
YOUR_NAME=Your Name
YOUR_OFFER=I build custom automation systems and AI-powered tools for coaches and real estate professionals that save time and increase revenue.
YOUR_PORTFOLIO_URL=https://yourportfolio.com
TARGET_PRICING_MIN=500
TARGET_PRICING_MAX=5000
